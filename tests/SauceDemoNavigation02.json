[
  {
    "id": "step-1",
    "action": "navigate",
    "target": "{{baseUrl}}",
    "metadata": {
      "originalEnglish": "Navigate to SauceDemo"
    }
  },
  {
    "id": "step-2",
    "action": "fill",
    "target": "LoginPage.usernameField",
    "value": "{{standardUser}}",
    "metadata": {
      "originalEnglish": "Enter standard user"
    }
  },
  {
    "id": "step-3",
    "action": "fill",
    "target": "LoginPage.passwordField",
    "value": "{{userPassword}}",
    "metadata": {
      "originalEnglish": "Enter password"
    }
  },
  {
    "id": "step-4",
    "action": "click",
    "target": "LoginPage.loginButton",
    "metadata": {
      "originalEnglish": "Click login button"
    }
  },
  {
    "id": "step-5",
    "action": "click",
    "target": "InventoryPage.hamburgerMenu",
    "metadata": {
      "originalEnglish": "Click hamburger menu"
    }
  },
  {
    "id": "step-6",
    "action": "click",
    "target": "NavMenu.logoutLink",
    "metadata": {
      "originalEnglish": "Click Logout link"
    }
  },
  {
    "id": "step-7",
    "action": "assertVisible",
    "target": "LoginPage.loginButton",
    "metadata": {
      "originalEnglish": "Verify redirected to login page"
    }
  }
]
