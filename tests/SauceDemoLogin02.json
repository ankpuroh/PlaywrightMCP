[
  {
    "id": "step-1",
    "action": "navigate",
    "target": "{{baseUrl}}",
    "metadata": {
      "originalEnglish": "Navigate to SauceDemo login page"
    }
  },
  {
    "id": "step-2",
    "action": "fill",
    "target": "LoginPage.usernameField",
    "value": "{{lockedUser}}",
    "metadata": {
      "originalEnglish": "Enter locked out user"
    }
  },
  {
    "id": "step-3",
    "action": "fill",
    "target": "LoginPage.passwordField",
    "value": "{{userPassword}}",
    "metadata": {
      "originalEnglish": "Enter password"
    }
  },
  {
    "id": "step-4",
    "action": "click",
    "target": "LoginPage.loginButton",
    "metadata": {
      "originalEnglish": "Click login button"
    }
  },
  {
    "id": "step-5",
    "action": "assertText",
    "target": "page",
    "assert": "Epic sadface: Sorry, this user has been locked out",
    "metadata": {
      "originalEnglish": "Verify error message for locked out user"
    }
  },
  {
    "id": "step-6",
    "action": "assertVisible",
    "target": "LoginPage.errorMessage",
    "metadata": {
      "originalEnglish": "Verify error banner is visible"
    }
  }
]
