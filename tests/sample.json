[
  {
    "id": "step-1",
    "action": "navigate",
    "target": "{{baseUrl}}",
    "metadata": {
      "originalEnglish": "Navigate to the application"
    }
  },
  {
    "id": "step-2",
    "action": "screenshot",
    "target": "homepage",
    "metadata": {
      "originalEnglish": "Take a screenshot of the homepage"
    }
  },
  {
    "id": "step-3",
    "action": "click",
    "target": "SamplePage.searchButton",
    "metadata": {
      "originalEnglish": "Click on the search button"
    }
  },
  {
    "id": "step-4",
    "action": "fill",
    "target": "SamplePage.searchInput",
    "value": "{{searchTerm}}",
    "metadata": {
      "originalEnglish": "Enter search term 'automation framework'"
    }
  },
  {
    "id": "step-5",
    "action": "press",
    "target": "search-form",
    "value": "Enter",
    "metadata": {
      "originalEnglish": "Press Enter to submit search"
    }
  },
  {
    "id": "step-6",
    "action": "waitFor",
    "target": "Search results for",
    "metadata": {
      "originalEnglish": "Wait for search results to appear"
    }
  },
  {
    "id": "step-7",
    "action": "assertText",
    "target": "search-results-container",
    "assert": "Search results for",
    "metadata": {
      "originalEnglish": "Verify search results are displayed"
    }
  },
  {
    "id": "step-8",
    "action": "screenshot",
    "target": "search-results",
    "metadata": {
      "originalEnglish": "Take screenshot of search results"
    }
  }
]
