[
  {
    "id": "step-1",
    "action": "navigate",
    "target": "{{baseUrl}}",
    "metadata": {
      "originalEnglish": "Navigate to SauceDemo"
    }
  },
  {
    "id": "step-2",
    "action": "fill",
    "target": "LoginPage.usernameField",
    "value": "{{standardUser}}",
    "metadata": {
      "originalEnglish": "Enter standard user"
    }
  },
  {
    "id": "step-3",
    "action": "fill",
    "target": "LoginPage.passwordField",
    "value": "{{userPassword}}",
    "metadata": {
      "originalEnglish": "Enter password"
    }
  },
  {
    "id": "step-4",
    "action": "click",
    "target": "LoginPage.loginButton",
    "metadata": {
      "originalEnglish": "Click login button"
    }
  },
  {
    "id": "step-5",
    "action": "click",
    "target": "InventoryPage.addToCartBackpack",
    "metadata": {
      "originalEnglish": "Click Add to Cart for backpack"
    }
  },
  {
    "id": "step-6",
    "action": "assertText",
    "target": "page",
    "assert": "1",
    "metadata": {
      "originalEnglish": "Verify cart badge shows 1 item"
    }
  },
  {
    "id": "step-7",
    "action": "screenshot",
    "target": "cart-badge-1",
    "metadata": {
      "originalEnglish": "Capture screenshot of cart badge"
    }
  }
