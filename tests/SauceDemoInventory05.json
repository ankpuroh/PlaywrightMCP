[
  {
    "id": "step-1",
    "action": "navigate",
    "target": "{{baseUrl}}",
    "metadata": {
      "originalEnglish": "Navigate to SauceDemo"
    }
  },
  {
    "id": "step-2",
    "action": "fill",
    "target": "LoginPage.usernameField",
    "value": "{{standardUser}}",
    "metadata": {
      "originalEnglish": "Enter standard user"
    }
  },
  {
    "id": "step-3",
    "action": "fill",
    "target": "LoginPage.passwordField",
    "value": "{{userPassword}}",
    "metadata": {
      "originalEnglish": "Enter password"
    }
  },
  {
    "id": "step-4",
    "action": "click",
    "target": "LoginPage.loginButton",
    "metadata": {
      "originalEnglish": "Click login button"
    }
  },
  {
    "id": "step-5",
    "action": "click",
    "target": "InventoryPage.firstProductLink",
    "metadata": {
      "originalEnglish": "Click on first product"
    }
  },
  {
    "id": "step-6",
    "action": "assertVisible",
    "target": "ProductDetailPage.productName",
    "metadata": {
      "originalEnglish": "Verify product name is visible"
    }
  },
  {
    "id": "step-7",
    "action": "assertVisible",
    "target": "ProductDetailPage.productPrice",
    "metadata": {
      "originalEnglish": "Verify price is visible"
    }
  },
  {
    "id": "step-8",
    "action": "assertVisible",
    "target": "ProductDetailPage.addToCartButton",
    "metadata": {
      "originalEnglish": "Verify add to cart button is visible"
    }
  },
  {
    "id": "step-9",
    "action": "assertVisible",
    "target": "ProductDetailPage.backButton",
    "metadata": {
      "originalEnglish": "Verify back button is visible"
    }
  },
  {
    "id": "step-10",
    "action": "screenshot",
    "target": "product-detail",
    "metadata": {
      "originalEnglish": "Capture product detail page screenshot"
    }
  }
]
