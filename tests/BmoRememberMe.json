[
  {
    "id": "step-1",
    "action": "navigate",
    "target": "{{bmoBaseUrl}}",
    "metadata": { "originalEnglish": "Open login page." }
  },
  {
    "id": "step-2",
    "action": "click",
    "target": "BmoLoginPage.rememberMeCheckbox",
    "metadata": { "originalEnglish": "Click Remember me checkbox once." }
  },
  {
    "id": "step-3",
    "action": "assertVisible",
    "target": "BmoLoginPage.rememberMeChecked",
    "metadata": { "originalEnglish": "Checkbox becomes selected." }
  },
  {
    "id": "step-4",
    "action": "click",
    "target": "BmoLoginPage.rememberMeCheckbox",
    "metadata": { "originalEnglish": "Click Remember me checkbox again." }
  },
  {
    "id": "step-5",
    "action": "assertVisible",
    "target": "BmoLoginPage.rememberMeUnchecked",
    "metadata": { "originalEnglish": "Checkbox becomes unselected. No unexpected validation or navigation occurs." }
  }
]
