[
  {
    "id": "step-1",
    "action": "navigate",
    "target": "{{bmoBaseUrl}}",
    "metadata": { "originalEnglish": "From login page." }
  },
  {
    "id": "step-2",
    "action": "click",
    "target": "BmoLoginPage.forgotPasswordLink",
    "metadata": { "originalEnglish": "Click FORGOT PASSWORD?." }
  },
  {
    "id": "step-3",
    "action": "assertVisible",
    "target": "BmoForgotPasswordPage.pageHeading",
    "metadata": { "originalEnglish": "Forgot Password page opens." }
  },
  {
    "id": "step-4",
    "action": "assertVisible",
    "target": "BmoForgotPasswordPage.userIdField",
    "metadata": { "originalEnglish": "Form includes User ID field." }
  },
  {
    "id": "step-5",
    "action": "assertVisible",
    "target": "BmoForgotPasswordPage.ssnTinOptions",
    "metadata": { "originalEnglish": "SSN/TIN options are present." }
  },
  {
    "id": "step-6",
    "action": "assertVisible",
    "target": "BmoForgotPasswordPage.continueButton",
    "metadata": { "originalEnglish": "Continue button is visible." }
  },
  {
    "id": "step-7",
    "action": "assertVisible",
    "target": "BmoForgotPasswordPage.cancelButton",
    "metadata": { "originalEnglish": "Cancel button is visible." }
  },
  {
    "id": "step-8",
    "action": "click",
    "target": "BmoForgotPasswordPage.cancelButton",
    "metadata": { "originalEnglish": "Click Cancel." }
  },
  {
    "id": "step-9",
    "action": "assertVisible",
    "target": "BmoLoginPage.signInButton",
    "metadata": { "originalEnglish": "User returns to login page. Login header and sign-in controls are visible again." }
  }
]
