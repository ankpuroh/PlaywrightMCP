[
  {
    "id": "step-1",
    "action": "navigate",
    "target": "{{baseUrl}}",
    "metadata": {
      "originalEnglish": "Navigate to SauceDemo"
    }
  },
  {
    "id": "step-2",
    "action": "fill",
    "target": "LoginPage.usernameField",
    "value": "{{standardUser}}",
    "metadata": {
      "originalEnglish": "Enter standard user"
    }
  },
  {
    "id": "step-3",
    "action": "fill",
    "target": "LoginPage.passwordField",
    "value": "{{userPassword}}",
    "metadata": {
      "originalEnglish": "Enter password"
    }
  },
  {
    "id": "step-4",
    "action": "click",
    "target": "LoginPage.loginButton",
    "metadata": {
      "originalEnglish": "Click login button"
    }
  },
  {
    "id": "step-5",
    "action": "assertText",
    "target": "page",
    "assert": "Products",
    "metadata": {
      "originalEnglish": "Verify Products heading visible"
    }
  },
  {
    "id": "step-6",
    "action": "assertVisible",
    "target": "InventoryPage.productList",
    "metadata": {
      "originalEnglish": "Verify product grid is visible"
    }
  },
  {
    "id": "step-7",
    "action": "assertText",
    "target": "page",
    "assert": "{{productBackpack}}",
    "metadata": {
      "originalEnglish": "Verify at least one product is visible"
    }
  }
]
