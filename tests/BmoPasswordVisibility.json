[
  {
    "id": "step-1",
    "action": "navigate",
    "target": "{{bmoBaseUrl}}",
    "metadata": { "originalEnglish": "Open login page." }
  },
  {
    "id": "step-2",
    "action": "fill",
    "target": "BmoLoginPage.passwordField",
    "value": "{{samplePassword}}",
    "metadata": { "originalEnglish": "Enter a sample password value in Password field." }
  },
  {
    "id": "step-3",
    "action": "assertVisible",
    "target": "BmoLoginPage.passwordField",
    "metadata": { "originalEnglish": "Password input masks characters by default." }
  },
  {
    "id": "step-4",
    "action": "click",
    "target": "BmoLoginPage.showPasswordToggle",
    "metadata": { "originalEnglish": "Click Show Password toggle." }
  },
  {
    "id": "step-5",
    "action": "assertVisible",
    "target": "BmoLoginPage.passwordFieldVisible",
    "metadata": { "originalEnglish": "Password becomes visible in plain text." }
  },
  {
    "id": "step-6",
    "action": "assertVisible",
    "target": "BmoLoginPage.showPasswordToggle",
    "metadata": { "originalEnglish": "Toggle control state changes to indicate visibility mode." }
  },
  {
    "id": "step-7",
    "action": "click",
    "target": "BmoLoginPage.showPasswordToggle",
    "metadata": { "originalEnglish": "Toggle again to hide password." }
  },
  {
    "id": "step-8",
    "action": "assertVisible",
    "target": "BmoLoginPage.passwordField",
    "metadata": { "originalEnglish": "Password is masked again. No field data is lost while toggling." }
  }
]
