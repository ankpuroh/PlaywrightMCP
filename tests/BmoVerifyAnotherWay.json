[
  {
    "id": "step-1",
    "action": "navigate",
    "target": "{{bmoBaseUrl}}",
    "metadata": { "originalEnglish": "Navigate to BMO login page." }
  },
  {
    "id": "step-2",
    "action": "click",
    "target": "BmoLoginPage.forgotUserIdLink",
    "metadata": { "originalEnglish": "Navigate to Forgot User ID page." }
  },
  {
    "id": "step-3",
    "action": "click",
    "target": "BmoForgotUserIdPage.verifyAnotherWayLink",
    "metadata": { "originalEnglish": "On Forgot User ID page, click Verify another way." }
  },
  {
    "id": "step-4",
    "action": "assertVisible",
    "target": "BmoVerifyAnotherWayPage.pageHeading",
    "metadata": { "originalEnglish": "Alternate Forgot User ID form opens." }
  },
  {
    "id": "step-5",
    "action": "assertVisible",
    "target": "BmoVerifyAnotherWayPage.emailField",
    "metadata": { "originalEnglish": "Email field requiring Email details is present." }
  },
  {
    "id": "step-6",
    "action": "assertVisible",
    "target": "BmoVerifyAnotherWayPage.ssnTinSection",
    "metadata": { "originalEnglish": "SSN/TIN details section is present." }
  },
  {
    "id": "step-7",
    "action": "assertVisible",
    "target": "BmoVerifyAnotherWayPage.backButton",
    "metadata": { "originalEnglish": "Back-to-previous-page control is present." }
  },
  {
    "id": "step-8",
    "action": "click",
    "target": "BmoVerifyAnotherWayPage.continueButton",
    "metadata": { "originalEnglish": "Without entering data, click Continue." }
  },
  {
    "id": "step-9",
    "action": "assertVisible",
    "target": "BmoVerifyAnotherWayPage.errorBanner",
    "metadata": { "originalEnglish": "Page-level validation banner appears." }
  },
  {
    "id": "step-10",
    "action": "assertVisible",
    "target": "BmoVerifyAnotherWayPage.emailValidationMsg",
    "metadata": { "originalEnglish": "Email required/format validation message appears." }
  },
  {
    "id": "step-11",
    "action": "assertVisible",
    "target": "BmoVerifyAnotherWayPage.ssnValidationMsg",
    "metadata": { "originalEnglish": "SSN validation message appears. No progression to next step occurs." }
  }
]
