[
  {
    "id": "step-1",
    "action": "navigate",
    "target": "{{baseUrl}}",
    "metadata": {
      "originalEnglish": "Navigate to SauceDemo"
    }
  },
  {
    "id": "step-2",
    "action": "fill",
    "target": "LoginPage.usernameField",
    "value": "{{standardUser}}",
    "metadata": {
      "originalEnglish": "Enter standard user"
    }
  },
  {
    "id": "step-3",
    "action": "fill",
    "target": "LoginPage.passwordField",
    "value": "{{userPassword}}",
    "metadata": {
      "originalEnglish": "Enter password"
    }
  },
  {
    "id": "step-4",
    "action": "click",
    "target": "LoginPage.loginButton",
    "metadata": {
      "originalEnglish": "Click login button"
    }
  },
  {
    "id": "step-5",
    "action": "select",
    "target": "InventoryPage.sortDropdown",
    "value": "{{sortOptionLoHi}}",
    "metadata": {
      "originalEnglish": "Select Price Low to High sort option"
    }
  },
  {
    "id": "step-6",
    "action": "assertText",
    "target": "page",
    "assert": "{{priceLowest}}",
    "metadata": {
      "originalEnglish": "Verify cheapest product appears first"
    }
  }
]
